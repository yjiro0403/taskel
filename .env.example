# ============================================================
# Taskel 環境変数テンプレート（.env.local にコピーして値を設定）
# ============================================================

# ---- Supabase（クライアント公開） ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase（サーバー専用・秘匿） ----
SUPABASE_SERVICE_ROLE_KEY=

# ---- アプリ URL（招待リンク・Stripe リダイレクト等の基点） ----
# 本番は実ドメイン、ローカルは http://localhost:3000。未設定だと
# https://taskel.vercel.app にフォールバックし、実ドメインと不一致になる。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to true only after configuring the Google provider in hosted Supabase Auth.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ---- AI（Gemini API） ----
GOOGLE_GENERATIVE_AI_API_KEY=your_api_key_here

# ---- Stripe（課金） ----
STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_BUSINESS_PRICE_ID=price_xxx
# クライアント側の課金ボタンはこの NEXT_PUBLIC_ 版を読む（ビルド時にバンドルへ焼き込まれるため
# Vercel のビルド環境変数にも登録が必要）。値はサーバー側と同じ price_xxx。
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_xxx

# ---- 招待メール送信（SMTP）----
# 未設定だと招待APIはメール送信をスキップして『Mock email sent』を返す（誰にも届かない）。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Taskel <noreply@example.com>"

# ---- Admin（クォータバイパス） ----
ADMIN_UIDS=your_supabase_user_id

# ============================================================
# データ移行スクリプト（scripts/migrate-to-supabase.ts）専用
#   `npm run migrate:supabase -- --dry-run` などで使用。上記 SUPABASE_SERVICE_ROLE_KEY と
#   NEXT_PUBLIC_SUPABASE_URL（または SUPABASE_URL）も必要。
# ============================================================
# 移行元 Firebase の読み取り資格情報（いずれか一方）
FIREBASE_SERVICE_ACCOUNT_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# 移行元 Firebase Storage バケット（添付ファイルのコピー元）
FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# サーバー用 Supabase URL エイリアス（NEXT_PUBLIC_SUPABASE_URL と同値でも可）
# SUPABASE_URL=
