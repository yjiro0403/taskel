rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: ユーザーが認証済みかチェック
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: 自分のデータかチェック
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper: プロジェクトメンバーかチェック
    function isProjectMember(projectId) {
      return request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    // Helper: プロジェクトオーナーかチェック
    function isProjectOwner(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // Projects: メンバーのみ読み取り可、オーナーのみ削除可
    match /projects/{projectId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberIds;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.memberIds;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Unified Tasks: オーナーまたはプロジェクトメンバーのみアクセス可
    match /tasks/{taskId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 500;
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.projectId != null && exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) && 
         request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberIds)
      );
    }

    // Unified Tags: オーナーのみアクセス可
    match /tags/{tagId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User Profile: 認証済みユーザーは読み取り可、自分のみ書き込み可
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // User Data (Subcollections): 自分のデータのみアクセス可
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Sections サブコレクション
    match /users/{userId}/sections/{sectionId} {
      allow read, write: if isOwner(userId);
    }
    
    // Routines サブコレクション
    match /users/{userId}/routines/{routineId} {
        allow read, write: if isOwner(userId);
    }

    // Subscriptions: ユーザー本人のみ読み取り、書き込みはサーバーのみ
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Usage: ユーザー本人のみ読み取り、書き込みはサーバーのみ
    match /usage/{userId}/monthly/{monthId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if false;
    }

    // Stripe Events: サーバーのみアクセス
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Invitations: 関係者のみアクセス可
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (
        resource.data.invitedBy == request.auth.uid ||
        resource.data.email == request.auth.token.email ||
        (resource.data.projectId != null && exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) && 
         request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberIds)
      );
      allow delete: if isAuthenticated() && (
        resource.data.invitedBy == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
    }
  }
}
